{
  "manifest_version": 3,
  "name": "MARK WhatsApp Bridge",
  "version": "8.1.0",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
